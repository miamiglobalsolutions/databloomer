# Production (Vercel + Neon) — required on databloomer.com
DATABASE_URL=
POSTGRES_URL=
NEXT_PUBLIC_APP_URL=https://databloomer.com

# Protect ingest API + Vercel cron
INGEST_SECRET=
CRON_SECRET=

# Weekly Bloom Zone email digest + contact/support forms (Resend — https://resend.com)
RESEND_API_KEY=
DIGEST_FROM_EMAIL=DataBloomer <digest@databloomer.com>
CONTACT_TO_EMAIL=support@databloomer.com
CONTACT_FROM_EMAIL=DataBloomer <support@databloomer.com>

# Google Search Console HTML tag verification (optional)
GOOGLE_SITE_VERIFICATION=

# Historical roofing permits — optional
SHOVELS_API_KEY=

# Aging roof window (years since last roof event)
ROOF_AGE_MIN_YEARS=13
ROOF_AGE_MAX_YEARS=25
ROOF_RECENT_EXCLUDE_YEARS=5

# County ingest — all Miami-Dade ZIPs, up to INGEST_MAX_PER_ZIP parcels each (~58k total)
INGEST_MAX_PER_ZIP=5000
# Weekly Vercel cron processes this many ZIPs per run (full cycle ~4 weeks)
INGEST_ZIPS_PER_CRON=20

# Dashboard / API lead fetch limits
LEADS_API_MAX=65000
LEADS_ZIP_MAX=5000

# Subscription gating + Stripe billing
SUBSCRIPTION_GATING=true
NEXT_PUBLIC_SUBSCRIPTION_GATING=true
SUBSCRIBER_ACCESS_CODE=
ADMIN_ACCESS_CODE=

# Stripe (https://dashboard.stripe.com)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

NEXT_PUBLIC_APP_URL=http://localhost:3000
