# Production (Vercel + Neon) — required on databloomer.com
DATABASE_URL=
POSTGRES_URL=
NEXT_PUBLIC_APP_URL=https://databloomer.com

# Protect ingest API + Vercel cron (weekly refresh)
INGEST_SECRET=
CRON_SECRET=

# Protect cron ingest endpoint (optional in dev)
INGEST_SECRET=

# Historical roofing permits — required for high-confidence 15-year leads
SHOVELS_API_KEY=

# Aging roof window (years since last roof event)
ROOF_AGE_MIN_YEARS=13
ROOF_AGE_MAX_YEARS=17
ROOF_RECENT_EXCLUDE_YEARS=5

# Max aging properties to pull per ingest (county has ~8,250 in the 13-17 yr window)
INGEST_MAX_PROPERTIES=8500

NEXT_PUBLIC_APP_URL=http://localhost:3000
